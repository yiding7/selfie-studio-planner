# Generic config. Prefer this if you may switch providers often.
# Supported LLM_PROVIDER values: zenmux, openai, openai-compatible, gemini, anthropic.
# Supported LLM_PROTOCOL values: chat, responses, anthropic.
# LLM_API_KEY=
# LLM_PROVIDER=zenmux
# LLM_PROTOCOL=chat
# LLM_MODEL=google/gemini-3.1-flash-lite
# LLM_BASE_URL=https://zenmux.ai/api/v1
# Optional: use ZenMux model routing instead of a fixed model.
# LLM_MODEL=zenmux/auto
# LLM_ROUTING_PREFERENCE=balanced
# LLM_ROUTING_MODELS=google/gemini-3.1-flash-lite,deepseek/deepseek-v4-flash,openai/chat-latest

# ZenMux convenience config. Used when LLM_API_KEY is not set.
ZENMUX_API_KEY=
ZENMUX_MODEL=google/gemini-3.1-flash-lite
ZENMUX_BASE_URL=https://zenmux.ai/api/v1
# Optional: use ZenMux model routing instead of a fixed model.
# ZENMUX_MODEL=zenmux/auto
# ZENMUX_ROUTING_PREFERENCE=balanced
# ZENMUX_ROUTING_MODELS=google/gemini-3.1-flash-lite,deepseek/deepseek-v4-flash,openai/chat-latest

# Image search. Used only when the frontend "图片搜索" switch is enabled.
# IMAGE_SEARCH_PROVIDER=brave
# BRAVE_SEARCH_API_KEY=
# BRAVE_IMAGE_SEARCH_ENDPOINT=https://api.search.brave.com/res/v1/images/search
# BRAVE_SEARCH_COUNTRY=US
# BRAVE_SEARCH_LANG=en
# BRAVE_SAFESEARCH=strict
# BRAVE_SPELLCHECK=1
# BRAVE_IMAGE_SEARCH_COUNT=20
# IMAGE_SEARCH_QUERIES_PER_GROUP=2

# OpenAI convenience config. Used when LLM_API_KEY and ZENMUX_API_KEY are not set.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini convenience config through Google's OpenAI-compatible endpoint.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Anthropic Claude native Messages API convenience config.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

PORT=5173
HOST=127.0.0.1
